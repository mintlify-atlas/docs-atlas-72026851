  "keyFeatures": [
    "Discover and browse popular/trending movies and TV shows via TMDB integration",
    "Create and manage multiple named collections (e.g., Watchlist, Favorites)",
    "Add media entries with personal ratings and notes",
    "Share collections and individual entries via password-protected or invite-only links",
    "Authentication via email/password, GitHub OAuth, and Google OAuth",
    "Default status collections: To Watch, Watching, Watched",
    "Dark/light theme support",
    "Docker Compose setup for local development with PostgreSQL"
  ],
  "publicApiSurface": [
    "GET /api/groups — list user's collections",
    "POST /api/groups — create a new collection",
    "GET /api/groups/[id] — get a specific collection",
    "PATCH /api/groups/[id] — update a collection",
    "DELETE /api/groups/[id] — delete a collection",
    "GET /api/groups/[id]/public — get a shared collection",
    "GET /api/media-entries — list media entries",
    "POST /api/media-entries — create or update a media entry",
    "GET /api/media-entries/[id] — get a specific media entry",
    "PATCH /api/media-entries/[id] — update a media entry",
    "DELETE /api/media-entries/[id] — delete a media entry",
    "POST /api/share/verify-password — verify a share password",
    "GET /api/user/profile — get user profile",
    "POST /api/user/change-password — change user password",
    "GET /api/tmdb/* — TMDB proxy endpoints"
  ]
}
